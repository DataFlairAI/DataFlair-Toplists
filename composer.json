{
    "name": "dataflair/toplists",
    "description": "WordPress plugin for managing and displaying DataFlair toplists and brands with API integration",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "keywords": [
        "wordpress",
        "plugin",
        "toplists",
        "brands",
        "casino",
        "affiliates",
        "dataflair"
    ],
    "authors": [
        {
            "name": "DataFlair",
            "email": "support@dataflair.ai"
        }
    ],
    "require": {
        "php": ">=8.1",
        "composer/installers": "^1.0 || ^2.0",
        "yahnis-elsts/plugin-update-checker": "^5.6"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0",
        "brain/monkey": "^2.6",
        "mockery/mockery": "^1.5"
    },
    "autoload": {
        "psr-4": {
            "DataFlair\\Toplists\\Models\\": "includes/",
            "DataFlair\\Toplists\\Cli\\": "includes/Cli/"
        }
    },
    "extra": {
        "installer-name": "dataflair-toplists"
    },
    "support": {
        "issues": "https://github.com/dataflair/toplists/issues",
        "source": "https://github.com/dataflair/toplists"
    },
    "scripts": {
        "install-prod": [
            "composer install --no-dev --prefer-dist --optimize-autoloader --no-interaction --no-progress"
        ],
        "install-dev": [
            "composer install --prefer-dist --optimize-autoloader --no-interaction --no-progress"
        ]
    },
    "config": {
        "allow-plugins": {
            "composer/installers": true
        },
        "preferred-install": "dist",
        "optimize-autoloader": true,
        "platform": {
            "php": "8.3.16"
        }
    }
}
